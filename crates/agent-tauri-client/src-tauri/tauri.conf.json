{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "agent-tauri-client",
  "version": "0.1.0",
  "identifier": "com.nuwax.agent-tauri-client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "agent-tauri-client",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/nuwax-lanproxy"],
    "resources": [
      "resources/node/bin/",
      "resources/node/lib/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUzNjg5RkExREZGQUVCNDIKUldSQzYvcmZvWjlvNDNIZkJNcmV1SHFtcForNVMvcTQycU1BRmlEUEd1ckFJanZLamZaU0x1K0IK",
      "endpoints": [
        "https://github.com/nuwax-ai/nuwax-agent-client/releases/latest/download/latest.json"
      ]
    },
    "cli": {
      "description": "NuWax Agent Desktop Client - 智能 Agent 桌面客户端",
      "args": [
        {
          "name": "tab",
          "description": "指定启动后跳转的 Tab 页面",
          "short": "t",
          "takesValue": true
        },
        {
          "name": "minimized",
          "description": "启动时最小化到系统托盘",
          "short": "m",
          "takesValue": false
        }
      ]
    }
  }
}
