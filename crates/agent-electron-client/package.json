{
  "name": "@nuwax/agent-electron-client",
  "version": "0.1.0",
  "description": "Nuwax Agent Desktop Client (Electron)",
  "main": "dist/main/main.js",
  "author": "Nuwax Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:main && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "build:electron": "npm run build && electron-builder",
    "dist": "npm run build:electron",
    "dist:mac": "npm run build:electron -- --mac",
    "dist:win": "npm run build:electron -- --win",
    "dist:linux": "npm run build:electron -- --linux",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@nuwax-ai/sdk": "file:../../vendors/opencode-sdk",
    "antd": "^5.29.3",
    "better-sqlite3": "^11.7.0",
    "dayjs": "^1.11.19",
    "electron-log": "^5.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.nuwax.agent",
    "productName": "Nuwax Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "better-sqlite3",
        "filter": ["*.node"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ]
  }
}
