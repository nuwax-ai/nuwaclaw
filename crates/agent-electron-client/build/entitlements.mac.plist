<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Electron 需要 V8 JIT 和可执行内存权限 -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- 允许加载动态链接库 (如 better-sqlite3) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- 网络访问 (后端 API、Agent 通信) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- 如果需要启动本地服务器 (如 file-server、computer-server) -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- 文件访问 (读写工作区文件) -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- 任意文件读写 (如果需要访问任意目录的工作区) -->
    <!-- 注意：App Store 分发不允许此权限，仅用于独立分发 -->
    <key>com.apple.security.temporary-exception.files.absolute.read-write</key>
    <array>
      <string>/</string>
    </array>

    <!-- 允许执行子进程 (启动 Agent 引擎、uv、lanproxy 等) -->
    <key>com.apple.security.cs.allow-executable-stack</key>
    <true/>
  </dict>
</plist>
