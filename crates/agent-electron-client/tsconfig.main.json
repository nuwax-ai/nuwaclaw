{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false
  },
  "include": [
    "src/main/**/*",
    "src/services/unifiedAgent.ts",
    "src/services/dependencies.ts",
    "src/services/engineManager.ts",
    "src/services/mcp.ts",
    "src/services/shellEnv.ts",
    "src/services/packageLocator.ts",
    "src/services/packageManager.ts",
    "src/types/**/*"
  ],
  "exclude": ["node_modules"]
}
