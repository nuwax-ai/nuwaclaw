# Generated by Cargo
# will have compiled files and executables
debug/
target/
.idea/
tmp/
logs/
# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

book
.DS_Store

# vcpkg：软链接或项目内安装目录，由 make setup-vcpkg 使用
vcpkg

# Node.js dependencies (root husky/lint-staged)
node_modules/
.cache/sidecars/
.cache/npm-tarballs/

# Electron/前端构建产物
dist/

# Bundled uv: 构建时 prepare-uv 生成，或从 GitHub Release 下载缓存
crates/agent-electron-client/resources/uv/bin/
crates/agent-electron-client/resources/uv/.cache/

# Bundled lanproxy: 构建时 prepare-lanproxy 从 Tauri binaries 复制当前平台二进制
crates/agent-electron-client/resources/lanproxy/bin/
